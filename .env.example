BSC_TRADER_WALLET=0x55976c6818e4794f3e2e7179eea2cc2202811e11
BSCSCAN_API_KEY=
BSC_RPC_URL=https://bsc.rpc.blxrbdn.com
FOURMEME_PROGRAM_MODE=rpc
RPC_LOG_CHUNK_SIZE=50000
RPC_MAX_BLOCKS_PER_RUN=50000
RPC_RECENT_BLOCKS_PER_RUN=80000
SITE_BASE_URL=https://hahahakang.github.io/bsc-fourmeme-analysis-live/

# Server listener: run this on a VPS for 10-second / block-level alerts.
LISTENER_POLL_SECONDS=10
LISTENER_CONFIRMATION_BLOCKS=2
LISTENER_LOOKBACK_BLOCKS=8
LISTENER_MAX_BLOCKS_PER_TICK=5000
LISTENER_LOG_CHUNK_SIZE=2000
LISTENER_BOOTSTRAP_BLOCKS=30
LISTENER_ALERT_LIMIT=500
LISTENER_NOTIFY_CHANNELS=console,json,web

# Optional alert channels.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_EMAIL_SUBJECT=BSC Four.meme trader alert
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true

# Paper-copy rules. Real trading is intentionally disabled in code.
COPYTRADE_DRY_RUN=true
COPYTRADE_FIRST_BUY_ONLY=true
COPYTRADE_MIN_SIGNAL_BNB=0.05
COPYTRADE_MAX_SIGNAL_BNB=2.0
COPYTRADE_PAPER_BNB=0.02
COPYTRADE_MAX_SIGNAL_AGE_SECONDS=45
COPYTRADE_MIN_FDV_USD=0
COPYTRADE_MAX_FDV_USD=50000
COPYTRADE_REQUIRE_MARKET_DATA=false
COPYTRADE_REQUIRE_SELL_SIMULATION=true
